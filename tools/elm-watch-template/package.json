{
  "private": true,
  "name": "elm-watch-template",
  "scripts": {
    "postinstall": "elm-tooling install",
    "start": "elm-watch hot",
    "build": "elm-watch make --optimize",
    "mini": "uglifyjs build/main.js --compress \"pure_funcs=[F2,F3,F4,F5,F6,F7,F8,F9,A2,A3,A4,A5,A6,A7,A8,A9],pure_getters,unsafe_comps,unsafe\" --mangle \"reserved=[F2,F3,F4,F5,F6,F7,F8,F9,A2,A3,A4,A5,A6,A7,A8,A9]\" --output build/main.min.js"
  },
  "devDependencies": {
    "elm-tooling": "^1.8.0",
    "elm-watch": "^1.0.1",
    "uglify-js": "^3.17.0" 
  }
}
